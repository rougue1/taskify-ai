# --- Database -----------------------------------------------------------------
# Async SQLAlchemy URL. SQLite for v0.1; swap for PostgreSQL (asyncpg) later.
DATABASE_URL=sqlite+aiosqlite:///./taskify.db

# --- Ollama / AI layer --------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TOOL_MODEL=qwen3:8b
OLLAMA_CODE_MODEL=qwen2.5-coder:14b
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- HTTP / CORS --------------------------------------------------------------
# JSON array or comma-separated list of allowed origins.
CORS_ORIGINS=["http://localhost:3000"]

# --- Runtime ------------------------------------------------------------------
APP_ENV=development
DEBUG=true
