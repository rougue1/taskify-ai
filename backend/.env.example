# --- Database -----------------------------------------------------------------
# Async SQLAlchemy URL. SQLite for v0.1; swap for PostgreSQL (asyncpg) later.
DATABASE_URL=sqlite+aiosqlite:///./taskify.db

# --- Ollama / AI layer --------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
# Tool-calling model. qwen3.5:9b emits <think>...</think> reasoning blocks.
OLLAMA_TOOL_MODEL=qwen3.5:9b
OLLAMA_CODE_MODEL=qwen2.5-coder:14b
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Agent --------------------------------------------------------------------
# Max LangGraph node visits per turn (loop guard).
AGENT_RECURSION_LIMIT=25
# Stream the model's native reasoning to the thinking UI (set false to disable).
OLLAMA_REASONING=true

# --- Auth / JWT ---------------------------------------------------------------
# Generate a strong secret for non-local use, e.g. `openssl rand -hex 32`.
JWT_SECRET_KEY=dev-insecure-change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- HTTP / CORS --------------------------------------------------------------
# JSON array or comma-separated list of allowed origins.
CORS_ORIGINS=["http://localhost:3000"]

# --- Runtime ------------------------------------------------------------------
APP_ENV=development
DEBUG=true
