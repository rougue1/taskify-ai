# ============================================================
# Taskify — environment for the Docker Compose stack (`make dev`)
# ------------------------------------------------------------
# Copy to `.env` and adjust. docker-compose.yml reads these values and builds
# the backend's DATABASE_URL / OLLAMA_BASE_URL from them using the in-network
# service hostnames, so you only set the building blocks below.
#
# For local (non-Docker) development instead, copy:
#   backend/.env.example  -> backend/.env
#   (frontend reads BACKEND_URL; defaults to http://localhost:8000)
# ============================================================

# ---------- PostgreSQL (the `postgres` service) ----------
# Powers semantic search via pgvector. The backend connects with these as
# postgresql+asyncpg://<user>:<password>@postgres:5432/<db>.
POSTGRES_USER=taskuser
POSTGRES_PASSWORD=taskpass
POSTGRES_DB=taskdb

# ---------- Auth / JWT ----------
# Generate a strong secret for any non-local use: `openssl rand -hex 32`
JWT_SECRET_KEY=dev-insecure-change-me-in-production

# ---------- Ollama models ----------
# Pulled by `make pull-models`. The tool model drives the chat agent; the embed
# model powers semantic search. Override if you prefer a different tool model.
OLLAMA_TOOL_MODEL=qwen3.5:9b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ---------- HTTP / runtime ----------
# JSON array or comma-separated list of browser origins allowed to call the API.
CORS_ORIGINS=["http://localhost:3000"]
APP_ENV=production
DEBUG=false
