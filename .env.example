# ============================================================
# Taskify — environment variable reference (overview)
# ------------------------------------------------------------
# Backend variables are read from   backend/.env
#   (template: backend/.env.example)
# Frontend variables are read from  frontend/.env.local
#   (template: frontend/.env.local.example)
# This root file documents them all in one place.
# ============================================================

# ---------- Backend (copy to backend/.env) ----------

# Async SQLAlchemy database URL. SQLite for v0.1; swap for PostgreSQL later.
DATABASE_URL=sqlite+aiosqlite:///./taskify.db

# Ollama server + model selection.
OLLAMA_BASE_URL=http://localhost:11434
# Tool-calling model. qwen3.5:9b emits <think>...</think> reasoning blocks.
OLLAMA_TOOL_MODEL=qwen3.5:9b
OLLAMA_CODE_MODEL=qwen2.5-coder:14b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Max LangGraph node visits per agent turn (loop guard).
AGENT_RECURSION_LIMIT=25
# Stream the model's native reasoning to the thinking UI (set false to disable).
OLLAMA_REASONING=true

# JWT auth. Override JWT_SECRET_KEY for any non-local use (`openssl rand -hex 32`).
JWT_SECRET_KEY=dev-insecure-change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Allowed CORS origins (JSON array or comma-separated list).
CORS_ORIGINS=["http://localhost:3000"]

# Runtime flags.
APP_ENV=development
DEBUG=true

# ---------- Frontend (copy to frontend/.env.local) ----------

# Base URL of the FastAPI backend, used by the Next.js proxy + health route.
BACKEND_URL=http://localhost:8000
